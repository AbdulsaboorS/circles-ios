---
import PhoneFrame from './PhoneFrame.astro';
import HabitDetailShell from './mockups/HabitDetailShell.astro';
import NoorBeadFill from './islands/NoorBeadFill.tsx';

/**
 * Section 4 — "Habits that Hold"
 *
 * Split layout: copy left, mockup right on desktop (alternating
 * rhythm from hero right → moment left → here right). Full-bleed
 * ms-background so it separates visually from Moment's deeper bg.
 *
 * Noor Bead fill animation lives in the NoorBeadFill island
 * wrapping the phone shell (SPEC §7 target #3).
 */
---

<section
  id="habits"
  class="habits"
  aria-labelledby="habits-title"
>
  <div class="habits__inner">
    <div class="habits__copy">
      <p class="habits__eyebrow">Habits that Hold</p>
      <h2 id="habits-title" class="habits__title">
        Built around your niyyah, not your streak.
      </h2>

      <div class="habits__body">
        <p>
          Set an intention. A 28-day roadmap forms around it — reviewed weekly,
          refined gently. No punishment for slipping.
        </p>
        <p>
          The Noor Bead fills with your presence, not your perfection.
          Consistency over streaks. Journey over outcome.
        </p>
      </div>

      <p class="habits__callout">
        Your streak can break. Your intention doesn&rsquo;t.
      </p>
    </div>

    <div class="habits__mockup" aria-label="Preview of a habit detail screen with the Noor streak ring" role="img">
      <NoorBeadFill client:visible>
        <PhoneFrame>
          <HabitDetailShell />
        </PhoneFrame>
      </NoorBeadFill>
    </div>
  </div>
</section>

<style>
  .habits {
    position: relative;
    background-color: var(--ms-background);
    padding: 96px 0 112px;
    overflow: hidden;
    border-top: 0.5px solid rgba(212, 162, 64, 0.08);
    border-bottom: 0.5px solid rgba(212, 162, 64, 0.08);
  }

  @media (min-width: 1024px) {
    .habits {
      padding: 128px 0 144px;
    }
  }

  /* Subtle radial tint, mirroring Moment but reversed (warm top-right) */
  .habits::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 85% 15%, rgba(212, 162, 64, 0.05), transparent 45%),
      radial-gradient(ellipse at 15% 85%, rgba(36, 56, 40, 0.5), transparent 55%);
    pointer-events: none;
  }

  .habits__inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .habits__inner {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      gap: 72px;
    }
  }

  /* ─── Copy ──────────────────────────────────────────── */
  .habits__copy {
    max-width: 540px;
  }

  .habits__eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ms-gold);
    margin: 0 0 20px;
  }

  .habits__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(34px, 5.4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ms-text-primary);
    margin: 0 0 28px;
  }

  .habits__body p {
    font-family: var(--font-sans);
    font-size: clamp(16px, 1.3vw, 18px);
    line-height: 1.6;
    color: var(--ms-text-muted);
    margin: 0 0 18px;
    max-width: 52ch;
  }

  .habits__body p:last-child {
    margin-bottom: 32px;
  }

  .habits__callout {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(16px, 1.3vw, 18px);
    color: var(--ms-text-primary);
    line-height: 1.45;
    padding: 14px 16px;
    background: rgba(212, 162, 64, 0.05);
    border-left: 2px solid var(--ms-gold);
    border-radius: 2px;
    margin: 0;
    max-width: 46ch;
  }

  /* ─── Mockup ────────────────────────────────────────── */
  .habits__mockup {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .habits__mockup {
      justify-self: end;
    }
  }
</style>
