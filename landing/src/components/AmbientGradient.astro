---
/**
 * Ambient amberâ†’forest gradient drift. Drop as the first child of a
 * `position: relative` section; it fills its parent absolutely.
 *
 * Animation: two stacked radial gradients whose `background-position`
 * shifts over 20s (SPEC Â§7 target #1). Honors `prefers-reduced-motion`.
 */
---

<div class="ambient" aria-hidden="true">
  <div class="ambient-layer ambient-layer--gold"></div>
  <div class="ambient-layer ambient-layer--forest"></div>
  <div class="ambient-vignette"></div>
</div>

<style>
  .ambient {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .ambient-layer {
    position: absolute;
    inset: -10%;
    background-size: 180% 180%;
  }

  .ambient-layer--gold {
    background-image: radial-gradient(
      circle at 20% 30%,
      rgba(212, 162, 64, 0.22) 0%,
      rgba(212, 162, 64, 0.05) 30%,
      transparent 55%
    );
    background-position: 0% 0%;
  }

  .ambient-layer--forest {
    background-image: radial-gradient(
      circle at 80% 70%,
      rgba(36, 56, 40, 0.45) 0%,
      rgba(19, 28, 20, 0.25) 40%,
      transparent 70%
    );
    background-position: 100% 100%;
  }

  /* Soft vignette so bright edges don't fight adjacent sections */
  .ambient-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 40%,
      rgba(19, 28, 20, 0.5) 100%
    );
  }

  @media (prefers-reduced-motion: no-preference) {
    .ambient-layer--gold {
      animation: gold-drift 22s ease-in-out infinite alternate;
    }

    .ambient-layer--forest {
      animation: forest-drift 26s ease-in-out infinite alternate;
    }
  }

  @keyframes gold-drift {
    from {
      background-position: 0% 0%;
    }
    to {
      background-position: 60% 40%;
    }
  }

  @keyframes forest-drift {
    from {
      background-position: 100% 100%;
    }
    to {
      background-position: 40% 60%;
    }
  }
</style>
