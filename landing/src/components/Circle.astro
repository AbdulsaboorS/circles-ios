---
import ScrollReveal from './islands/ScrollReveal.tsx';

/**
 * Section 3 — "Your Circle"
 *
 * Three-column feature strip on desktop, stacked on mobile. Each column
 * staggers into view via the ScrollReveal island (SPEC §7 target #4).
 *
 * Copy is single-version per SPEC §5 (only hero gets A/B).
 *
 * Glyphs are inline SVG to match HomeShell / MomentShell house style
 * (no icon font / Lucide component). That also keeps this section
 * zero-JS beyond the reveal island itself.
 */
---

<section
  id="circle"
  class="circle"
  aria-labelledby="circle-title"
>
  <div class="circle__inner">
    <header class="circle__header">
      <p class="circle__eyebrow">Your Circle</p>
      <h2 id="circle-title" class="circle__title">
        Small, private, and yours.
      </h2>
    </header>

    <ScrollReveal client:visible stagger={120}>
      <div class="circle__grid">
        <article class="circle__col" data-reveal>
          <div class="circle__icon" aria-hidden="true">
            <!-- lock-keyhole -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="var(--ms-gold)" stroke-width="1.6"
              stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="11" width="16" height="10" rx="2" />
              <path d="M8 11V7a4 4 0 0 1 8 0v4" />
              <circle cx="12" cy="15.5" r="1.4" fill="var(--ms-gold)" stroke="none" />
              <path d="M12 16.5v2" />
            </svg>
          </div>
          <h3 class="circle__h3">Private by default.</h3>
          <p class="circle__body">
            No public profiles. No discovery. Nothing you post ever
            leaves your circle.
          </p>
        </article>

        <article class="circle__col" data-reveal>
          <div class="circle__icon" aria-hidden="true">
            <!-- users (two silhouettes) -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="var(--ms-gold)" stroke-width="1.6"
              stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="8" r="3.2" />
              <path d="M3 20c.6-3.2 3-5 6-5s5.4 1.8 6 5" />
              <circle cx="17" cy="9" r="2.6" />
              <path d="M15.6 14.4c2.6.4 4.4 2 4.9 4.6" />
            </svg>
          </div>
          <h3 class="circle__h3">Small by design.</h3>
          <p class="circle__body">
            A circle is five or six people who already know you.
            Accountability from the few, not likes from the many.
          </p>
        </article>

        <article class="circle__col" data-reveal>
          <div class="circle__icon" aria-hidden="true">
            <!-- moon (matches home icon language) -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="var(--ms-gold)" stroke-width="1.6"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.5 14.3A8.5 8.5 0 0 1 9.7 3.5a8.5 8.5 0 1 0 10.8 10.8Z"
                fill="rgba(212,162,64,0.12)" />
            </svg>
          </div>
          <h3 class="circle__h3">Gender-aware.</h3>
          <p class="circle__body">
            Circles are brothers-only, sisters-only, or mixed — set at
            creation. Modesty stays structural, not a toggle.
          </p>
        </article>
      </div>
    </ScrollReveal>
  </div>
</section>

<style>
  .circle {
    position: relative;
    background-color: var(--ms-background);
    padding: 96px 0 112px;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .circle {
      padding: 128px 0 144px;
    }
  }

  /* Ultra-soft radial tint so the section doesn't read flat next to Moment's
     deeper backdrop. Very subtle — no animation, no cost. */
  .circle::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(212, 162, 64, 0.04), transparent 55%);
    pointer-events: none;
  }

  .circle__inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ─── Header ─────────────────────────────────────────── */
  .circle__header {
    max-width: 720px;
    margin: 0 auto 56px;
    text-align: center;
  }

  @media (min-width: 1024px) {
    .circle__header {
      margin-bottom: 72px;
    }
  }

  .circle__eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ms-gold);
    margin: 0 0 20px;
  }

  .circle__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(34px, 5.4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ms-text-primary);
    margin: 0;
  }

  /* ─── Grid ───────────────────────────────────────────── */
  .circle__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 768px) {
    .circle__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 48px;
    }
  }

  /* ─── Column ─────────────────────────────────────────── */
  .circle__col {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 320px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .circle__col {
      align-items: flex-start;
      text-align: left;
      max-width: none;
      margin: 0;
    }
  }

  .circle__icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(212, 162, 64, 0.10);
    border: 0.5px solid rgba(212, 162, 64, 0.28);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    filter: drop-shadow(0 0 10px rgba(212, 162, 64, 0.22));
  }

  .circle__h3 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 22px;
    letter-spacing: -0.015em;
    color: var(--ms-text-primary);
    margin: 0 0 10px;
  }

  .circle__body {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ms-text-muted);
    margin: 0;
    max-width: 36ch;
  }
</style>
